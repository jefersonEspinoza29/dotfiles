{
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",

  "control-center-margin-top": 40,
  "control-center-margin-right": 20,
  "control-center-margin-bottom": 20,
  "control-center-margin-left": 20,

  "control-center-width": 360,
  "control-center-height": 640,
  "notification-window-width": 360,

  "timeout": 5,
  "timeout-low": 5,
  "timeout-critical": 8,

  "widgets": [
    "title",
    "dnd",
    "volume",
    "backlight",
    "mpris",
    "notifications"
  ],

  "widget-config": {
    "title": {
      "text": "Notificaciones",
      "clear-all-button": true,
      "button-text": "Limpiar"
    },
    "dnd": {
      "text": "No molestar"
    },
    "volume": {
      "label": "󰕾"
    },
    "backlight": {
      "label": "󰃟",
      "device": "nvidia_wmi_ec_backlight",
      "subsystem": "backlight",
      "min": 1
    },
    "mpris": {
      "image-size": 64,
      "image-radius": 8
    },
    "notifications": {
      "vexpand": true
    }
  }
}
