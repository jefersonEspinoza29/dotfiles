{
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",

  "control-center-margin-top": 40,
  "control-center-margin-right": 20,
  "control-center-margin-bottom": 20,
  "control-center-margin-left": 20,

  "control-center-width": 360,
  "control-center-height": 640,
  "notification-window-width": 360,

  "timeout": 5,

  "widgets": [
    "title",
    "dnd",
    "slider#volume",
    "slider#brightness",
    "mpris",
    "notifications"
  ],

  "widget-config": {
    "title": {
      "text": "Notificaciones",
      "clear-all-button": true,
      "button-text": "Limpiar"
    },
    "dnd": {
      "text": "No molestar"
    },
    "slider#volume": {
      "label": "󰕾",
      "cmd_getter": "wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{printf \"%d\", $2 * 100}'",
      "cmd_setter": "wpctl set-volume @DEFAULT_AUDIO_SINK@ $value%",
      "min": 0,
      "max": 100
    },
    "slider#brightness": {
      "label": "󰃟",
      "cmd_getter": "brillo -G | awk '{printf \"%d\", $1}'",
      "cmd_setter": "brillo -S $value",
      "min": 1,
      "max": 100
    },
    "mpris": {
      "image-size": 64,
      "image-radius": 8
    },
    "notifications": {
      "vexpand": true
    }
  }
}
