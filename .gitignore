# Ignorar todo por defecto para no subir caches, perfiles o datos privados.
*

# Archivos base del repo.
!.gitignore

# Carpetas de configuracion versionadas.
!eww/
!eww/**
!hypr/
!hypr/**
!kitty/
!kitty/**
!matugen/
!matugen/**
!swaync/
!swaync/**
